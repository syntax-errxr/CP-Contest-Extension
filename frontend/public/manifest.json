{
  "manifest_version": 3,
  "name": "CP Extension",
  "version": "1.0.0",
  "description": "Unified dashboard for competitive programmers to track ratings, contests, and upsolve progress.",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "identity"
  ],
  "action": {
    "default_popup": "index.html",
    "default_title": "CP Extension"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
